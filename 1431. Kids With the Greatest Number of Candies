class Solution:
    def kidsWithCandies(self, candies: List[int], extraCandies: int) -> List[bool]:
        max_candies=max(candies)
        result= []
        for candy in candies:
            added_candies= candy+ extraCandies
            if added_candies>= max_candies:
                result.append(True)
            else:
                result.append(False)
        return result
            
