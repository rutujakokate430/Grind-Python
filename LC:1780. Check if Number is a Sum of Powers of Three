1780. Check if Number is a Sum of Powers of Three

class Solution:
    def checkPowersOfThree(self, n: int) -> bool:
        if n<=0: return False
        result=0

        while n!=0:
            rem= n%3
            if rem>1:
                return False 
            result*=rem
            n=n//3

        
        return True

        

        
