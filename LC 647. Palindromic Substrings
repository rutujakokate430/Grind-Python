class Solution:
    def countSubstrings(self, s: str) -> int:
        def is_palindrome(word):
            return word == word[::-1]

        
        output=0
        
        for l in range(len(s)):
            for r in range(l+1, len(s)+1):
                if is_palindrome(s[l:r]):
                    output+=1
        
        return output
               


        
